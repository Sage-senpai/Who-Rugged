# WHO RUGGED? environment
# Copy to .env and fill in. Never commit the real .env. Fund the key at faucet.0g.ai.

# 0G networks. Players pick testnet (free) or mainnet (real) in the Profile.
# Galileo testnet (defaults from docs.0g.ai):
VITE_RPC_URL=https://evmrpc-testnet.0g.ai
VITE_OG_CHAIN_ID=16602
VITE_OG_CHAIN_NAME=0G Galileo Testnet
VITE_OG_CURRENCY_SYMBOL=0G
VITE_OG_EXPLORER=https://chainscan-galileo.0g.ai
VITE_OG_FAUCET=https://faucet.0g.ai
# Aristotle mainnet (defaults from docs.0g.ai):
VITE_OG_MAINNET_CHAIN_ID=16661
VITE_OG_MAINNET_NAME=0G Aristotle Mainnet
VITE_OG_MAINNET_RPC=https://evmrpc.0g.ai
VITE_OG_MAINNET_EXPLORER=https://chainscan.0g.ai
# Which network is selected by default (testnet | mainnet):
VITE_DEFAULT_NETWORK=testnet
VITE_VAULT_ADDRESS=

# 0G Compute (Sealed Inference, OpenAI-compatible router)
# Server side only. Do NOT prefix with VITE_ or it ships to the browser.
ZG_COMPUTE_ROUTER=https://router-api.0g.ai/v1
PRIVATE_KEY=

# 0G Storage
STORAGE_INDEXER=https://indexer-storage-testnet-turbo.0g.ai

# Multiplayer lobby (Cloudflare Durable Object in server/). Leave blank to
# disable multiplayer; the lobby screen then shows a "not configured" state.
# After `cd server && npm run deploy`, set this to the worker's wss URL.
VITE_LOBBY_URL=

# 0G Compute server (same worker in server/, https origin). Leave blank to run
# the AI fully local (mock). When set, the solo case seals roles server-side and
# generates suspect statements + suspicion reads via 0G Compute. The compute key
# itself lives ONLY in server/.dev.vars or `wrangler secret`, never here.
VITE_COMPUTE_URL=

# WHO SOLD? prediction market. Points to the same worker as VITE_COMPUTE_URL.
# Leave blank to show the "not configured" state on /sold.
# Worker secrets (add via `wrangler secret put`): ALCHEMY_API_KEY, ANSEM_MINT,
# SOLD_SELL_THRESHOLD (default 0.10), SOLD_PREDICTION_WINDOW_HOURS (default 12).
VITE_SOLD_URL=
